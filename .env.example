# =============================================================================
#  poly_hft .env reference
# =============================================================================
#
#  YOU DO NOT FILL THIS FILE IN BY HAND.
#
#  The setup scripts create and update a real `.env` for you. This file just
#  documents which variables exist and which script writes each one, so you
#  know what to expect after each step.
#
#  Standard setup, in order:
#
#    1. scripts/generate_wallet.py            -> creates .env with the keys below
#    2. (you fund the wallet on Polygon)
#    3. scripts/wrap_to_pusd.py               -> no .env changes
#    4. scripts/migrate_to_deposit_wallet.py  -> sets FUNDER_ADDRESS + SIGNATURE_TYPE + DEPOSIT_WALLET_ADDRESS
#    5. scripts/derive_api_creds.py           -> sets the three CLOB_API_* values
#
#  See README.md for the full walkthrough.
# =============================================================================


# --- Created by scripts/generate_wallet.py ---
# Your fresh trading wallet. NEVER share PRIVATE_KEY.
PRIVATE_KEY=0x<64 hex chars>
WALLET_ADDRESS=0x<your EOA address>

# Defaults to the EOA, then changed to the deposit wallet by step 4.
FUNDER_ADDRESS=0x<your EOA address>

# 0 = raw EOA (rejected by Polymarket V2)
# 3 = Polymarket V2 deposit wallet (POLY_1271) -- this is what step 4 sets
SIGNATURE_TYPE=0


# --- Network (you usually don't touch these) ---
CHAIN_ID=137
# Public RPC is fine to start. For HFT, swap in Alchemy or QuickNode.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# --- Polymarket endpoints (you usually don't touch these) ---
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com


# --- Created by scripts/derive_api_creds.py ---
# L2 API key derived from your private-key signature. The bot uses these to
# authenticate every order. Treat as a password.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=


# --- Created by scripts/migrate_to_deposit_wallet.py ---
# Your Polymarket V2 deposit wallet address. Differs from WALLET_ADDRESS.
# This is also where your funds live after step 4.
DEPOSIT_WALLET_ADDRESS=
